    },
    {
      "prompt": "They ____ soccer yesterday.",
      "options": ["play", "plays", "played", "playing"],
      "answerIndex": 2,
      "explanation": "yesterday 表示昨天，play 的過去式是 played。"
    },
    {
      "prompt": "Tom ____ to school this morning.",
      "options": ["walk", "walks", "walked", "walking"],
      "answerIndex": 2,
