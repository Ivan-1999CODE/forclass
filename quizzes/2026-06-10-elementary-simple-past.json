    },
    {
      "prompt": "My brother ____ a book last Sunday.",
      "options": ["read", "reads", "reading", "readed"],
      "answerIndex": 0,
      "explanation": "read 的過去式拼法也是 read，但發音不同；last Sunday 表示過去時間。"
    },
    {
      "prompt": "We ____ at home yesterday.",
      "options": ["are", "is", "was", "were"],
      "answerIndex": 3,
      "explanation": "We 是複數主詞，be 動詞的過去式要用 were。"
    },
    {
      "prompt": "Lisa ____ happy yesterday.",
      "options": ["is", "are", "was", "were"],
      "answerIndex": 2,
      "explanation": "Lisa 是單數主詞，yesterday 表示過去時間，所以用 was。"
    },
    {
      "prompt": "Did you ____ your hands?",
      "options": ["wash", "washes", "washed", "washing"],
      "answerIndex": 0,
      "explanation": "Did 開頭的過去式問句，後面的動詞要用原形 wash。"
    },
